{
  "name": "@kibadist/agentui-validate",
  "version": "1.0.0",
  "description": "AgentUI validation utilities",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kibadist/agentui.git",
    "directory": "packages/validate"
  },
  "homepage": "https://github.com/kibadist/agentui#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "schema:generate": "tsx scripts/generate-schemas.ts",
    "schema:check": "tsx scripts/generate-schemas.ts --check"
  },
  "dependencies": {
    "@kibadist/agentui-protocol": "workspace:^",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "ajv": "^8.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "zod-to-json-schema": "^3.24.1"
  },
  "bugs": {
    "url": "https://github.com/kibadist/agentui/issues"
  },
  "keywords": [
    "agent",
    "zod",
    "validation",
    "schema",
    "wire-protocol",
    "agentui"
  ]
}
