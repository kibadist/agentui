{
  "name": "@kibadist/agentui-svg",
  "version": "1.4.0",
  "description": "SVG-native Web Components for visualizing agent workflows, timelines, approvals, memory, and state",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kibadist/agentui.git",
    "directory": "packages/svg"
  },
  "homepage": "https://github.com/kibadist/agentui#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": [
    "./dist/register.js",
    "./dist/components/*.js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "bugs": {
    "url": "https://github.com/kibadist/agentui/issues"
  },
  "keywords": [
    "svg",
    "web-components",
    "custom-elements",
    "agent",
    "ui",
    "llm",
    "visualization",
    "agentui"
  ]
}
